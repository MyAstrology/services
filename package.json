{
  "name": "myastrology",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "generate-list": "node src/content/blog/generate-list.js",
    "generate-related": "node generate-related-posts.js",
    "generate-posts": "node generate-posts.js",
    "generate-all": "npm run generate-list && npm run generate-related && npm run generate-posts",
    "generate-rashifal": "node src/content/rashifal/generate-rashifal.js",
    "generate-news-sitemap": "node src/content/rashifal/generate-news-sitemap.js",
    "generate-rashifal-all": "npm run generate-rashifal && npm run generate-news-sitemap",
    "build": "npm run generate-all",
    "watch": "node watch.js",
    "watch-simple": "node auto-generate.js",
    "deploy": "npm run build && git add . && git commit -m \"Auto-build: $(date)\" && git push"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "chokidar": "^3.6.0"
  }
}
